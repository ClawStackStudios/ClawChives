# ─── ClawChives Environment Configuration ─────────────────────────────────────
# Copy this file to .env and uncomment the desired settings.
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Server URL ─────────────────────────────────────────────────────────────
# Required for connecting the frontend to the backend server.
#
# Local Dev:        http://localhost:4646       (npm start / scuttle:dev-start)
# LAN/Self-Hosted:  http://192.168.1.6:4646    (Replace IP with your machine's LAN IP)
# Docker:           Leave unset (uses relative paths, same-origin)
# Custom Domain:    https://bookmarks.yourdomain.com

VITE_API_URL=http://localhost:4646

# ── Security ──────────────────────────────────────────────────────────────────
# Enable "trust proxy" if the server is behind a trusted reverse proxy (e.g., Nginx, Docker, LB)
# This is required for correct IP detection when using rate limiting or HTTPS redirection.
# TRUST_PROXY=true
