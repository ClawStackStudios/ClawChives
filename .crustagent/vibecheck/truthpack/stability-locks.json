{
  "version": "2.0",
  "project": "ClawChives-v2",
  "locks": {
    "network": {
      "ui_port": 4545,
      "api_port": 4646,
      "env_config_source": "src/config/apiConfig.ts",
      "dev_vite_host": "localhost (security: dev-only)",
      "prod_vite_host": "0.0.0.0 (deployment: LAN-accessible)",
      "express_host": "0.0.0.0 (implicit, all interfaces)",
      "prod_build_first": "scuttle:prod-start must build before serving"
    },
    "crypto": {
      "char_set_size": 62,
      "key_length": 64,
      "unbiased_generation": true,
      "rejection_sampling_limit": 248,
      "hash_algorithm": "SHA-256"
    },
    "auth": {
      "one_field_login": true,
      "session_storage_only": true,
      "namespaced_keys": "cc_*",
      "required_middleware": [
        "requireAuth",
        "requireHuman",
        "requirePermission"
      ]
    },
    "database": {
      "engine": "better-sqlite3 (or better-sqlite3-multiple-ciphers with SQLCipher)",
      "journal_mode": "WAL",
      "foreign_keys": "ON",
      "encryption": "AES-256 via DB_ENCRYPTION_KEY (SQLCipher drop-in)",
      "constraints": {
        "key_hash": "UNIQUE",
        "user_uuid": "REQUIRED"
      }
    },
    "runtime": {
      "node_version_target": "22",
      "tsx_watch_no_ignore": true
    },
    "testing": {
      "framework": "Vitest + Supertest",
      "real_database": "HardShell suite uses actual SQLite (never mocked)",
      "test_phases": "Unit → Integration → Error Paths → Security",
      "test_helpers_location": "tests/helpers/ (testDb.ts, testAuth.ts, testFactories.ts)",
      "required_before_commit": true
    },
    "docker": {
      "npm_install_strategy": "npm install (NOT --omit=dev) — keeps tsx at runtime",
      "cmd_format": "CMD [\"npx\", \"tsx\", \"server.ts\"] — uses npx to locate tsx",
      "entrypoint_logic": "pass-through only — exec su-exec node \"$@\" without adding commands",
      "healthcheck_start_period": "15s minimum for better-sqlite3 initialization",
      "image_build": "Copy only source files, never COPY . . (prevents stale dist/)",
      "failure_signature": "su-exec: tsx: No such file or directory = check npm install and CMD"
    },
    "ui": {
      "sync_theme_initialization": true,
      "visual_hierarchy_lock": true
    }
  },
  "deployment": {
    "cloudflare_tunnel": "Fully supported — see README.md Public Deployment section",
    "https_redirect": "ENFORCE_HTTPS middleware + x-forwarded-proto check",
    "cors_modes": {
      "development": "Allow all localhost + LAN IPs",
      "lan_production": "Allow LAN IPs only (when CORS_ORIGIN unset)",
      "strict": "Allowlist via CORS_ORIGIN env var (for CF Tunnel + reverse proxy)"
    },
    "environment_variables": {
      "DB_ENCRYPTION_KEY": "AES-256 key (optional, plaintext if unset)",
      "TRUST_PROXY": "true for CF Tunnel (reads x-forwarded-proto, real client IP)",
      "CORS_ORIGIN": "Comma-separated list for strict mode (e.g., https://your-domain.com)",
      "ENFORCE_HTTPS": "true to redirect HTTP → HTTPS"
    }
  },
  "status": "STABLE_LOCKED",
  "last_lock_update": "2026-03-17T00:00:00Z",
  "maintained_by": "CrustAgent©™"
}
